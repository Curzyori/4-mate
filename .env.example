# 4 Mate — Environment Variables
# PANDUAN PENGISIAN:
# 1. Salin file ini dan ubah namanya menjadi .env.local
# 2. Isi semua URL API di bawah ini sesuai dengan provider yang Anda gunakan.
# 3. Jangan hapus tanda kutip jika ada spasi, tapi biasanya URL tidak perlu tanda kutip.

# ── Spotify ──
# Gunakan endpoint dari Spotmate atau proxy Spotify sejenis
SPOTIFY_API_URL=https://spotmate.online

# ── TikTok ──
# Masukkan URL API endpoint untuk TikTok downloader (Contoh: https://www.tikwm.com/api/)
TIKTOK_API_URL=https://www.tikwm.com/api/

# ── Optional Config ──
# ID Google Analytics jika ingin melacak trafik
NEXT_PUBLIC_GA_ID=
